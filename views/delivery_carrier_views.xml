<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_carrier_form_cs" model="ir.ui.view">
        <field name="name">delivery.carrier.form.inherit.circular_shipping</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Circular Shipping">
                    <field name="cs_is_office_carrier" widget="boolean_toggle"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
